    <LineIds Name="fb_MoverPositionOffsetData.Identity.Set">
      <LineId Id="1" Count="1" />
    </LineIds>
    <LineIds Name="fb_MoverPositionOffsetData.MoverOffsets.Set">
      <LineId Id="1" Count="1" />
    </LineIds>
    <LineIds Name="fb_MoverPositionOffsetData.State.Set">
      <LineId Id="1" Count="1" />
    </LineIds>
  </POU>
